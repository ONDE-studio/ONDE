# ONDE Studio — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Find in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — keep secret, server-only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=

# ─── Site URL ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://onde-studio.ru

# ─── Telegram ────────────────────────────────────────────────────────────────
# Get from @BotFather: /newbot then /token
TELEGRAM_BOT_TOKEN=
# Chat ID where order notifications go (admin chat or channel)
# Use @userinfobot or similar to get your chat ID
TELEGRAM_ADMIN_CHAT_ID=
# Public Telegram channel/username for customer CTA button
TELEGRAM_PUBLIC_USERNAME=onde_studio

# ─── Security ─────────────────────────────────────────────────────────────────
# Random secret for HMAC IP hashing in rate limiter (generate: openssl rand -hex 32)
RATE_LIMIT_SECRET=
# Secret for protecting the Vercel Cron endpoint (generate: openssl rand -hex 32)
CRON_SECRET=

# ─── Shipping Providers (optional) ───────────────────────────────────────────
# СДЭК API v2 — register at: https://www.cdek.ru/ru/api
# Without these, CDEK is disabled and manual Telegram agreement is used
CDEK_CLIENT_ID=
CDEK_CLIENT_SECRET=

# Russian Post — register at: https://otpravka.pochta.ru/
RUSSIAN_POST_API_TOKEN=
RUSSIAN_POST_USER_AUTH_KEY=

# Yandex B2B Delivery — contact Yandex for business account
YANDEX_DELIVERY_API_TOKEN=

# ─── Origin Warehouse Address (Shatura) ─────────────────────────────────────
SHIPPING_ORIGIN_COUNTRY=RU
SHIPPING_ORIGIN_REGION=Московская область
SHIPPING_ORIGIN_CITY=Шатура
SHIPPING_ORIGIN_POSTAL_CODE=140700
SHIPPING_ORIGIN_ADDRESS=ул. Школьная, д. 15
